<Patch>
<!-- Adding custom wood as fuel-->
  <Operation Class="PatchOperationAdd">
    <xpath>
      /Defs/ThingDef[
        comps/li[@Class="CompProperties_Refuelable"]
        /fuelFilter/thingDefs/li[text()="WoodLog"]
      ]
      /comps/li[@Class="CompProperties_Refuelable"]
      /fuelFilter/thingDefs
    </xpath>
    <value>
      <li>JA_WoodOak</li>
      <li>JA_WoodMaple</li>
      <li>JA_WoodTeak</li>
      <li>JA_WoodCypress</li>
      <li>JA_WoodPine</li>
      <li>JA_WoodBirch</li>
      <li>JA_WoodPoplar</li>
      <li>JA_WoodWillow</li>
